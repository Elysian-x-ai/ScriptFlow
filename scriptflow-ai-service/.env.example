# AI Provider: claude | deepseek | openai | mock
AI_PROVIDER=mock

# API Keys (required for real providers)
CLAUDE_API_KEY=sk-ant-xxxxxxxx
DEEPSEEK_API_KEY=sk-xxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxx

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Queue names
QUEUE_TASK=scriptflow.task.submit
QUEUE_RESULT=scriptflow.task.result
QUEUE_LOG=scriptflow.task.log

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
